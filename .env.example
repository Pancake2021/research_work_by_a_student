# ======================================================
# HuggingFace — токен для загрузки моделей
# Получить здесь: https://huggingface.co/settings/tokens
# ======================================================
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ======================================================
# Weights & Biases — логирование метрик
# Получить здесь: https://wandb.ai/authorize
# ======================================================
WANDB_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
WANDB_PROJECT=behavior-analysis-rl-llm
WANDB_ENTITY=your-wandb-username

# ======================================================
# Настройки модели
# ======================================================
MODEL_NAME=unsloth/Qwen2.5-1.5B-Instruct
MAX_SEQ_LENGTH=2048
LOAD_IN_4BIT=true

# ======================================================
# Пути к данным
# ======================================================
DATA_DIR=./data
OUTPUT_DIR=./outputs
CHECKPOINT_DIR=./checkpoints

# ======================================================
# Colab MCP bridge (для удалённого запуска экспериментов)
# ======================================================
COLAB_MCP_URL=https://example.ngrok-free.app
COLAB_MCP_API_KEY=your-colab-mcp-secret
